# =====================================================================
# PocketOption AI Signal Pro - Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local. Only NEXT_PUBLIC_* vars are exposed to the browser.
# =====================================================================

# --- Supabase (public) ---
# Found in: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# --- Supabase (server-only, NEVER expose to client) ---
# Service role key bypasses RLS. Used only in server actions / route handlers / edge functions.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-secret-key"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="PocketOption AI Signal Pro"
NEXT_PUBLIC_SUPPORT_TELEGRAM="@devtech77"

# --- License signing (server-only) ---
# Secret used to sign/verify license activation payloads & device fingerprints.
LICENSE_SIGNING_SECRET="generate-a-long-random-string"

# --- Market data ---
# Yahoo Finance is used via public endpoints (no key required) for forex,
# indices and commodities. Optional override base URL.
MARKET_DATA_BASE_URL="https://query1.finance.yahoo.com"
# Crypto uses Binance's public DATA host (no API key, not geo-restricted).
# Do NOT use api.binance.com here — it returns HTTP 451 from US IPs (e.g. Vercel iad1).
BINANCE_BASE_URL="https://data-api.binance.vision"
# Seconds between live price polls (respect rate limits).
NEXT_PUBLIC_MARKET_REFRESH_SECONDS="5"

# --- Optional: OTC data provider (configured per-pair in admin too) ---
OTC_PROVIDER_API_KEY=""
OTC_PROVIDER_BASE_URL=""
